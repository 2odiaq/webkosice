# Public site URL used for SEO (sitemap, OG, canonical)
NEXT_PUBLIC_SITE_URL=https://example.com

# Email destination for contact form submissions
CONTACT_EMAIL=hello@example.com

# Verified domain in Resend — "From" for contact emails (email or "Name <email>").
# Defaults to noreply@send.webkosice.com if unset.
RESEND_FROM=noreply@send.webkosice.com

# Resend API key — when set, the contact form sends real emails.
# Without it, the form falls back to a mailto: flow (still fully functional).
# Get a key at https://resend.com
RESEND_API_KEY=re_ALg8nZwT_HYNeo6hxeAne4gR1WvGARYc9
